			return cairo.Surface.g_lib.call('mint_cairo_image_surface_get_height', self.d_ptr)
		}

		/**
		 * Returns the number of bytes between rows.
		 */
		const def get_stride(self) {
			return cairo.Surface.g_lib.call('mint_cairo_image_surface_get_stride', self.d_ptr)
		}

		/**
		 * Returns the image pixel format.
		 */
		const def get_format(self) {
			return cairo.Surface.g_lib.call('mint_cairo_image_surface_get_format', self.d_ptr)
		}

	}

