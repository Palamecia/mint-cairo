load mint.type

package cairo {

	enum Antialias {
		DEFAULT
		NONE
		GRAY
		SUBPIXEL
		FAST
		GOOD
		BEST
	}

	enum Content {
		COLOR
		ALPHA
		COLOR_ALPHA
	}

	enum FontSlant {
		NORMAL
		ITALIC
		OBLIQUE
	}

	enum FontWeight {
		NORMAL
		BOLD
	}

	enum FillRule {
		WINDING
		EVEN_ODD
	}

	enum Format {
		ARGB32
		RGB24
		A8
		A1
		RGB16_565
		RGB30
	}

	enum LineCap {
		BUTT
		ROUND
		SQUARE
	}

	enum LineJoin {
		MITER
		ROUND
		BEVEL
	}

	enum Operator {
		CLEAR
		SOURCE
		OVER
		IN
		OUT
		ATOP
		DEST
		DEST_OVER
		DEST_IN
		DEST_OUT
		DEST_ATOP
		XOR
		ADD
		SATURATE
		MULTIPLY
		SCREEN
		OVERLAY
		DARKEN
		LIGHTEN
		COLOR_DODGE
		COLOR_BURN
		HARD_LIGHT
		SOFT_LIGHT
		DIFFERENCE
		EXCLUSION
		HSL_HUE
		HSL_SATURATION
		HSL_COLOR
		HSL_LUMINOSITY
	}

	enum PatternType {
		SOLID
		SURFACE
		LINEAR
		RADIAL
		MESH
		RASTER_SOURCE
	}

	enum SurfaceType {
		IMAGE
		PDF
		PS
		XLIB
		XCB
		GLITZ
		QUARTZ
		WIN32
		BEOS
		DIRECTFB
		SVG
		OS2
		WIN32_PRINTING
		QUARTZ_IMAGE
		SCRIPT
		QT
		RECORDING
		VG
		GL
		DRM
		TEE
		XML
		SKIA
		SUBSURFACE
		COGL
	}

	/**
	 * Context is the main object used when drawing with cairo. To draw with
	 * cairo, you create a Context, set the target surface, and drawing options
	 * for the Context, create shapes with functions like {Context.move_to()}
	 * and {Context.line_to}(), and then draw shapes with {Context.stroke}() or
	 * {Context.fill}().
	 * 
	 * Contexts can be pushed to a stack via {Context.save}(). They may then
	 * safely be changed, without losing the current state. Use
	 * {Context.restore}() to restore to the saved state.
	 */
	class Context {
		/**
		 * Creates a new Context with all graphics state parameters set to
		 * default values and with `target` as a target surface. The target
		 * surface should be constructed with a backend-specific function such
		 * as {ImageSurface} (or any other cairo backend surface create variant).
		 */
		const def new(self, target) {
			self.d_ptr = cairo.Context.g_lib.call('mint_cairo_create', target.to_cairo_surface_t())
			self.d_ptr.delete = def [g_lib = cairo.Context.g_lib] (self) {
				g_lib.call('mint_cairo_destroy', self)
			}
			return self
		}

		/**
		 * Append the `path` onto the current path. The path may be either the
		 * return value from one of {Context.copy_path}() or
		 * {Context.copy_path_flat}() or it may be constructed manually (in C).
		 */
		const def append_path(self, path) {
			cairo.Context.g_lib.call('mint_cairo_append_path', self.d_ptr, path.to_cairo_path_t())
		}

		/**
		 * Creates a copy of the current path. The returned {Path} owns its
		 * native path data and may be appended to this or another context.
		 */
		const def copy_path(self) {
			return cairo.Path(cairo.Context.g_lib.call('mint_cairo_copy_path', self.d_ptr))
		}

		/**
		 * Creates a flattened copy of the current path, where curves are
		 * approximated with line segments.
		 */
		const def copy_path_flat(self) {
			return cairo.Path(cairo.Context.g_lib.call('mint_cairo_copy_path_flat', self.d_ptr))
		}

		/**
		 * Saves the current graphics state on the context stack.
		 */
		const def save(self) {
			cairo.Context.g_lib.call('mint_cairo_save', self.d_ptr)
		}

		/**
		 * Restores the most recently saved graphics state.
		 */
		const def restore(self) {
			cairo.Context.g_lib.call('mint_cairo_restore', self.d_ptr)
		}

		/**
		 * Redirects drawing to a temporary group with the same content type as
		 * the current target.
		 */
		const def push_group(self) {
			cairo.Context.g_lib.call('mint_cairo_push_group', self.d_ptr)
		}

		/**
		 * Redirects drawing to a temporary group with an explicit content type.
		 */
		const def push_group_with_content(self, content) {
			cairo.Context.g_lib.call('mint_cairo_push_group_with_content', self.d_ptr, content.toNumber())
		}

		/**
		 * Ends the current group and returns it as a {Pattern}.
		 */
		const def pop_group(self) {
			return cairo.Pattern(cairo.Context.g_lib.call('mint_cairo_pop_group', self.d_ptr))
		}

		/**
		 * Ends the current group and sets it as the current source.
		 */
		const def pop_group_to_source(self) {
			cairo.Context.g_lib.call('mint_cairo_pop_group_to_source', self.d_ptr)
		}

		/**
		 * Adds a circular arc of the given `radius` to the current path. The arc
		 * is centered at (`xc`, `yc`), begins at `angle1` and proceeds in the
		 * direction of increasing angles to end at `angle2`. If `angle2` is less
		 * than `angle1` it will be progressively increased by 2*PI until it is
		 * greater than `angle1`.
		 * 
		 * If there is a current point, an initial line segment will be added to
		 * the path to connect the current point to the beginning of the arc. If
		 * this initial line is undesired, it can be avoided by calling
		 * {Context.new_sub_path}() before calling {Context.arc}().
		 * 
		 * Angles are measured in radians. An angle of 0.0 is in the direction
		 * of the positive X axis (in user space). An angle of PI/2.0 radians
		 * (90 degrees) is in the direction of the positive Y axis (in user
		 * space). Angles increase in the direction from the positive X axis
		 * toward the positive Y axis. So with the default transformation matrix,
		 * angles increase in a clockwise direction.
		 * 
		 * To convert from degrees to radians, use degrees * (math.pi / 180).
		 * 
		 * This function gives the arc in the direction of increasing angles;
		 * see {Context.arc_negative}() to get the arc in the direction of
		 * decreasing angles.
		 * 
		 * The arc is circular in user space. To achieve an elliptical arc, you
		 * can scale the current transformation matrix by different amounts in
		 * the X and Y directions. For example, to draw an ellipse in the box
		 * given by x, y, width, height:
		 * 
		 * ```mn
		 * ctx.save()
		 * ctx.translate(x + width / 2., y + height / 2.)
		 * ctx.scale(width / 2., height / 2.)
		 * ctx.arc(0., 0., 1., 0., 2 * math.pi)
		 * ctx.restore()
		 * ```
		 */
		const def arc(self, xc, yc, radius, angle1, angle2) {
			cairo.Context.g_lib.call('mint_cairo_arc', self.d_ptr, xc.toNumber(), yc.toNumber(), radius.toNumber(), angle1.toNumber(), angle2.toNumber())
		}

		/**
		 * Adds a circular arc of the given `radius` to the current path. The arc
		 * is centered at (`xc`, `yc`), begins at `angle1` and proceeds in the
		 * direction of decreasing angles to end at `angle2`. If `angle2` is
		 * greater than `angle1` it will be progressively decreased by 2*PI until
		 * it is less than `angle1`.
		 * 
		 * See {Context.arc}() for more details. This function differs only in
		 * the direction of the arc between the two angles.
		 */
		const def arc_negative(self, xc, yc, radius, angle1, angle2) {
			cairo.Context.g_lib.call('mint_cairo_arc_negative', self.d_ptr, xc.toNumber(), yc.toNumber(), radius.toNumber(), angle1.toNumber(), angle2.toNumber())
		}

		/**
		 * Adds a cubic Bezier spline to the current path.
		 */
		const def curve_to(self, x1, y1, x2, y2, x3, y3) {
			cairo.Context.g_lib.call('mint_cairo_curve_to', self.d_ptr, x1.toNumber(), y1.toNumber(), x2.toNumber(), y2.toNumber(), x3.toNumber(), y3.toNumber())
		}

		/**
		 * Closes the current sub-path by drawing a line to its start point.
		 */
		const def close_path(self) {
			cairo.Context.g_lib.call('mint_cairo_close_path', self.d_ptr)
		}

		/**
		 * Clears the current path.
		 */
		const def new_path(self) {
			cairo.Context.g_lib.call('mint_cairo_new_path', self.d_ptr)
		}

		/**
		 * Starts a new sub-path without connecting it to the previous one.
		 */
		const def new_sub_path(self) {
			cairo.Context.g_lib.call('mint_cairo_new_sub_path', self.d_ptr)
		}

		/**
		 * Begins a new sub-path at (`x`, `y`).
		 */
		const def move_to(self, x, y) {
			cairo.Context.g_lib.call('mint_cairo_move_to', self.d_ptr, x.toNumber(), y.toNumber())
		}

		/**
		 * Adds a line segment from the current point to (`x`, `y`).
		 */
		const def line_to(self, x, y) {
			cairo.Context.g_lib.call('mint_cairo_line_to', self.d_ptr, x.toNumber(), y.toNumber())
		}

		/**
		 * Moves the current point by (`dx`, `dy`) relative to its current
		 * position.
		 */
		const def rel_move_to(self, dx, dy) {
			cairo.Context.g_lib.call('mint_cairo_rel_move_to', self.d_ptr, dx.toNumber(), dy.toNumber())
		}

		/**
		 * Adds a line segment by (`dx`, `dy`) relative to the current point.
		 */
		const def rel_line_to(self, dx, dy) {
			cairo.Context.g_lib.call('mint_cairo_rel_line_to', self.d_ptr, dx.toNumber(), dy.toNumber())
		}

		/**
		 * Adds a rectangular closed sub-path.
		 */
		const def rectangle(self, x, y, width, height) {
			cairo.Context.g_lib.call('mint_cairo_rectangle', self.d_ptr, x.toNumber(), y.toNumber(), width.toNumber(), height.toNumber())
		}

		/**
		 * Establishes a new clip region by intersecting the current clip region
		 * with the current path as it would be filled by {Context.fill}() and
		 * according to the current fill rule (see {Context.set_fill_rule}()).
		 * 
		 * After {clip}(), the current path will be cleared from the Context.
		 * 
		 * The current clip region affects all drawing operations by effectively
		 * masking out any changes to the surface that are outside the current
		 * clip region.
		 * 
		 * Calling {clip}() can only make the clip region smaller, never larger.
		 * But the current clip is part of the graphics state, so a temporary
		 * restriction of the clip region can be achieved by calling {clip}()
		 * within a {Context.save}()/{Context.restore}() pair. The only other
		 * means of increasing the size of the clip region is {Context.reset_clip}().
		 */
		const def clip(self) {
			cairo.Context.g_lib.call('mint_cairo_clip', self.d_ptr)
		}

		/**
		 * Like {Context.clip}(), but keeps the current path.
		 */
		const def clip_preserve(self) {
			cairo.Context.g_lib.call('mint_cairo_clip_preserve', self.d_ptr)
		}

		/**
		 * Resets the clip region to the target surface extents.
		 */
		const def reset_clip(self) {
			cairo.Context.g_lib.call('mint_cairo_reset_clip', self.d_ptr)
		}

		/**
		 * Computes a bounding box in user coordinates covering the area inside
		 * the current clip.
		 * 
		 * Returns an iterator containing :
		 * * `x1`: left of the resulting extents
		 * * `y1`: top of the resulting extents
		 * * `x2`: right of the resulting extents
		 * * `y2`: bottom of the resulting extents
		 */
		const def clip_extents(self) {
			return cairo.Context.g_lib.call('mint_cairo_clip_extents', self.d_ptr)
		}

		/**
		 * Fills the current path using the current source and fill rule.
		 */
		const def fill(self) {
			cairo.Context.g_lib.call('mint_cairo_fill', self.d_ptr)
		}

		/**
		 * Like {Context.fill}(), but keeps the current path.
		 */
		const def fill_preserve(self) {
			cairo.Context.g_lib.call('mint_cairo_fill_preserve', self.d_ptr)
		}

		/**
		 * Computes the extents of the area that would be filled.
		 */
		const def fill_extents(self) {
			return cairo.Context.g_lib.call('mint_cairo_fill_extents', self.d_ptr)
		}

		/**
		 * Returns true when (`x`, `y`) is inside the current fill path.
		 */
		const def in_fill(self, x, y) {
			return cairo.Context.g_lib.call('mint_cairo_in_fill', self.d_ptr, x.toNumber(), y.toNumber())
		}

		/**
		 * Strokes the current path using the current stroke style.
		 */
		const def stroke(self) {
			cairo.Context.g_lib.call('mint_cairo_stroke', self.d_ptr)
		}

		/**
		 * Like {Context.stroke}(), but keeps the current path.
		 */
		const def stroke_preserve(self) {
			cairo.Context.g_lib.call('mint_cairo_stroke_preserve', self.d_ptr)
		}

		/**
		 * Computes the extents of the area that would be stroked.
		 */
		const def stroke_extents(self) {
			return cairo.Context.g_lib.call('mint_cairo_stroke_extents', self.d_ptr)
		}

		/**
		 * Returns true when (`x`, `y`) is inside the current stroked path.
		 */
		const def in_stroke(self, x, y) {
			return cairo.Context.g_lib.call('mint_cairo_in_stroke', self.d_ptr, x.toNumber(), y.toNumber())
		}

		/**
		 * Paints the current source everywhere within the clip region.
		 */
		const def paint(self) {
			cairo.Context.g_lib.call('mint_cairo_paint', self.d_ptr)
		}

		/**
		 * Paints the current source with an additional alpha value.
		 */
		const def paint_with_alpha(self, alpha) {
			cairo.Context.g_lib.call('mint_cairo_paint_with_alpha', self.d_ptr, alpha.toNumber())
		}

		/**
		 * Emits the current page without clearing it.
		 */
		const def copy_page(self) {
			cairo.Context.g_lib.call('mint_cairo_copy_page', self.d_ptr)
		}

		/**
		 * Emits and clears the current page for paginated backends.
		 */
		const def show_page(self) {
			cairo.Context.g_lib.call('mint_cairo_show_page', self.d_ptr)
		}

		/**
		 * Sets the source to an opaque RGB color. Components are in the range
		 * 0.0 to 1.0.
		 */
		const def set_source_rgb(self, red, green, blue) {
			cairo.Context.g_lib.call('mint_cairo_set_source_rgb', self.d_ptr, red.toNumber(), green.toNumber(), blue.toNumber())
		}

		/**
		 * Sets the source to an RGBA color. Components are in the range 0.0 to
		 * 1.0.
		 */
		const def set_source_rgba(self, red, green, blue, alpha) {
			cairo.Context.g_lib.call('mint_cairo_set_source_rgba', self.d_ptr, red.toNumber(), green.toNumber(), blue.toNumber(), alpha.toNumber())
		}

		/**
		 * Sets the source pattern used by subsequent drawing operations.
		 */
		const def set_source(self, pattern) {
			cairo.Context.g_lib.call('mint_cairo_set_source', self.d_ptr, pattern.to_cairo_pattern_t())
		}

		/**
		 * Sets a surface as the source, positioned at (`x`, `y`).
		 */
		const def set_source_surface(self, surface, x, y) {
			cairo.Context.g_lib.call('mint_cairo_set_source_surface', self.d_ptr, surface.to_cairo_surface_t(), x.toNumber(), y.toNumber())
		}

		/**
		 * Masks the current source through `pattern`.
		 */
		const def mask(self, pattern) {
			cairo.Context.g_lib.call('mint_cairo_mask', self.d_ptr, pattern.to_cairo_pattern_t())
		}

		/**
		 * Masks the current source through `surface`.
		 */
		const def mask_surface(self, surface, surface_x, surface_y) {
			cairo.Context.g_lib.call('mint_cairo_mask_surface', self.d_ptr, surface.to_cairo_surface_t(), surface_x.toNumber(), surface_y.toNumber())
		}

		/**
		 * Sets the current line width.
		 */
		const def set_line_width(self, width) {
			cairo.Context.g_lib.call('mint_cairo_set_line_width', self.d_ptr, width.toNumber())
		}

		/**
		 * Returns the current line width.
		 */
		const def get_line_width(self) {
			return cairo.Context.g_lib.call('mint_cairo_get_line_width', self.d_ptr)
		}

		/**
		 * Sets the current miter limit.
		 */
		const def set_miter_limit(self, limit) {
			cairo.Context.g_lib.call('mint_cairo_set_miter_limit', self.d_ptr, limit.toNumber())
		}

		/**
		 * Returns the current miter limit.
		 */
		const def get_miter_limit(self) {
			return cairo.Context.g_lib.call('mint_cairo_get_miter_limit', self.d_ptr)
		}

		/**
		 * Sets the tolerance used when converting curves to trapezoids.
		 */
		const def set_tolerance(self, tolerance) {
			cairo.Context.g_lib.call('mint_cairo_set_tolerance', self.d_ptr, tolerance.toNumber())
		}

		/**
		 * Returns the current tolerance.
		 */
		const def get_tolerance(self) {
			return cairo.Context.g_lib.call('mint_cairo_get_tolerance', self.d_ptr)
		}

		/**
		 * Sets the compositing operator.
		 */
		const def set_operator(self, op) {
			cairo.Context.g_lib.call('mint_cairo_set_operator', self.d_ptr, op.toNumber())
		}

		/**
		 * Returns the current compositing operator.
		 */
		const def get_operator(self) {
			return cairo.Context.g_lib.call('mint_cairo_get_operator', self.d_ptr)
		}

		/**
		 * Sets the antialiasing mode.
		 */
		const def set_antialias(self, antialias) {
			cairo.Context.g_lib.call('mint_cairo_set_antialias', self.d_ptr, antialias.toNumber())
		}

		/**
		 * Returns the current antialiasing mode.
		 */
		const def get_antialias(self) {
			return cairo.Context.g_lib.call('mint_cairo_get_antialias', self.d_ptr)
		}

		/**
		 * Sets the fill rule used by fill and clip operations.
		 */
		const def set_fill_rule(self, fill_rule) {
			cairo.Context.g_lib.call('mint_cairo_set_fill_rule', self.d_ptr, fill_rule.toNumber())
		}

		/**
		 * Returns the current fill rule.
		 */
		const def get_fill_rule(self) {
			return cairo.Context.g_lib.call('mint_cairo_get_fill_rule', self.d_ptr)
		}

		/**
		 * Sets the line cap style.
		 */
		const def set_line_cap(self, line_cap) {
			cairo.Context.g_lib.call('mint_cairo_set_line_cap', self.d_ptr, line_cap.toNumber())
		}

		/**
		 * Returns the current line cap style.
		 */
		const def get_line_cap(self) {
			return cairo.Context.g_lib.call('mint_cairo_get_line_cap', self.d_ptr)
		}

		/**
		 * Sets the line join style.
		 */
		const def set_line_join(self, line_join) {
			cairo.Context.g_lib.call('mint_cairo_set_line_join', self.d_ptr, line_join.toNumber())
		}

		/**
		 * Returns the current line join style.
		 */
		const def get_line_join(self) {
			return cairo.Context.g_lib.call('mint_cairo_get_line_join', self.d_ptr)
		}

		/**
		 * Applies a translation to the current transformation matrix.
		 */
		const def translate(self, tx, ty) {
			cairo.Context.g_lib.call('mint_cairo_translate', self.d_ptr, tx.toNumber(), ty.toNumber())
		}

		/**
		 * Applies a scale to the current transformation matrix.
		 */
		const def scale(self, sx, sy) {
			cairo.Context.g_lib.call('mint_cairo_scale', self.d_ptr, sx.toNumber(), sy.toNumber())
		}

		/**
		 * Applies a rotation, in radians, to the current transformation matrix.
		 */
		const def rotate(self, angle) {
			cairo.Context.g_lib.call('mint_cairo_rotate', self.d_ptr, angle.toNumber())
		}

		/**
		 * Resets the current transformation matrix to the identity matrix.
		 */
		const def identity_matrix(self) {
			cairo.Context.g_lib.call('mint_cairo_identity_matrix', self.d_ptr)
		}

		/**
		 * Converts a point from user coordinates to device coordinates.
		 */
		const def user_to_device(self, x, y) {
			return cairo.Context.g_lib.call('mint_cairo_user_to_device', self.d_ptr, x.toNumber(), y.toNumber())
		}

		/**
		 * Converts a distance from user coordinates to device coordinates.
		 */
		const def user_to_device_distance(self, dx, dy) {
			return cairo.Context.g_lib.call('mint_cairo_user_to_device_distance', self.d_ptr, dx.toNumber(), dy.toNumber())
		}

		/**
		 * Converts a point from device coordinates to user coordinates.
		 */
		const def device_to_user(self, x, y) {
			return cairo.Context.g_lib.call('mint_cairo_device_to_user', self.d_ptr, x.toNumber(), y.toNumber())
		}

		/**
		 * Converts a distance from device coordinates to user coordinates.
		 */
		const def device_to_user_distance(self, dx, dy) {
			return cairo.Context.g_lib.call('mint_cairo_device_to_user_distance', self.d_ptr, dx.toNumber(), dy.toNumber())
		}

		/**
		 * Returns the current point as (`x`, `y`).
		 */
		const def get_current_point(self) {
			return cairo.Context.g_lib.call('mint_cairo_get_current_point', self.d_ptr)
		}

		/**
		 * Computes the extents of the current path.
		 */
		const def path_extents(self) {
			return cairo.Context.g_lib.call('mint_cairo_path_extents', self.d_ptr)
		}

		/**
		 * Returns the current context status code.
		 */
		const def status(self) {
			return cairo.Context.g_lib.call('mint_cairo_status', self.d_ptr)
		}

		/**
		 * Selects a toy font face for simple text drawing.
		 */
		const def select_font_face(self, family, slant = cairo.FontSlant.NORMAL, weight = cairo.FontWeight.NORMAL) {
			cairo.Context.g_lib.call('mint_cairo_select_font_face', self.d_ptr, family, slant.toNumber(), weight.toNumber())
		}

		/**
		 * Sets the current toy font size in user-space units.
		 */
		const def set_font_size(self, size) {
			cairo.Context.g_lib.call('mint_cairo_set_font_size', self.d_ptr, size.toNumber())
		}

		/**
		 * Draws UTF-8 text at the current point.
		 */
		const def show_text(self, text) {
			cairo.Context.g_lib.call('mint_cairo_show_text', self.d_ptr, text)
		}

		/**
